# Optional. Leave unset and the system runs fully on rule-based query parsing
# + BLIP-ITM verification instead of LLM-based parsing/verification.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional overrides
# FASHION_DATA_DIR=data/images
# FASHION_INDEX_DIR=data/index
# GEMINI_MODEL=gemini-2.5-flash-lite
# FASHION_USE_SEGMENTATION=1   # set to 0 to force the legacy MediaPipe-pose color path

# Notes on GEMINI_API_KEY / free-tier quota:
#   - Every LLM call (query parsing + candidate verification) is cached on
#     disk at data/index/llm_cache.jsonl -- re-running the same query twice
#     costs zero extra quota. Safe to delete this file any time; it will
#     just be rebuilt.
#   - retriever/search.py only sends the top few candidates per query to the
#     LLM for verification (config.MAX_LLM_VERIFY_CANDIDATES), not all of
#     them, for the same reason.
#   - Free-tier daily request limits vary by model and change over time --
#     check https://ai.google.dev/gemini-api/docs/rate-limits if you hit a
#     429 RESOURCE_EXHAUSTED error. The system remains fully functional with
#     GEMINI_API_KEY unset (or once quota runs out mid-session -- failures
#     here degrade gracefully, they never crash a query).
